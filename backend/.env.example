# ODE OMR V2 — Backend environment variables
# Copy to .env and fill in real values

# PostgreSQL connection URL (sviluppo)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nssp_v2

# PostgreSQL connection URL (test — database separato, DL-ARCH-V2-003 §7)
DATABASE_URL_TEST=postgresql://postgres:postgres@localhost:5432/nssp_v2_test

# Runtime environment
APP_ENV=development
DEBUG=false

# JWT — cambiare JWT_SECRET_KEY prima dell'uso in produzione
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
